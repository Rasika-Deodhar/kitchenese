# Groq API key used server-side only. Never expose this to the frontend.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of origins allowed to call this API (your frontend URL(s)).
# Example for local dev: http://localhost:5173
# Example for production: https://kitchenese.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
